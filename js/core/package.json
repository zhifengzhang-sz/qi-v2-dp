{
  "name": "@qi/core",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "jest",
    "docs:clean": "rm -rf ../docs/api",
    "docs:build": "npm run docs:clean && typedoc --options typedoc.json",
    "docs:serve": "npx serve ../docs",
    "docs:watch": "nodemon --watch src -e ts,tsx --exec npm run docs:build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.5",
    "pg": "^8.13.1",
    "sequelize": "^6.37.5",
    "winston": "^3.16.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.8.4",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "serve": "^14.2.1",
    "ts-jest": "^29.2.5",
    "typedoc": "^0.26.11",
    "typedoc-plugin-markdown": "^4.2.10",
    "typescript": "^5.6.3"
  },
  "exports": {
    "./": "./dist/index.js",

    "./core": "./dist/core/index.js",
    "./core/*": "./dist/core/*/index.js",

    "./cli": "./dist/cli/index.js",
    "./cli/*": "./dist/cli/*/index.js",
    "./cli/schemas/*": "./dist/cli/schemas/*.js",

    "./config": "./dist/config/index.js",
    "./config/schemas/*": "./dist/config/schemas/*.js",
    
    "./errors": "./dist/errors/index.js",
    "./errors/*": "./dist/errors/*/index.js",

    "./logger": "./dist/logger/index.js",

    "./services": "./dist/services/index.js",
    "./services/*": "./dist/services/*/index.js",
    "./services/kafka": "./dist/services/kafka/index.js",
    "./services/kafka/*": "./dist/services/kafka/*/index.js",
    "./services/redis": "./dist/services/redis/index.js",
    "./services/schemas/*": "./dist/services/schemas/*.js",
    "./services/timescaledb": "./dist/services/timescaledb/index.js",
    "./services/timescaledb/models": "./dist/services/timescaledb/models/index.js",
    "./services/timescaledb/models/*": "./dist/services/timescaledb/models/*/index.js",

    "./cache": "./dist/cache/index.js",
    "./cache/*": "./dist/cache/*/index.js",

    "./utils": "./dist/utils/index.js",
    "./utils/*": "./dist/utils/*/index.js",

    "./websocket": "./dist/websocket/index.js",
    "./websocket/*": "./dist/websocket/*/index.js"
  }
}
