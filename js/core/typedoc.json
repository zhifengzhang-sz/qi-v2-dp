{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/index.ts"],
  "out": "../docs/api",
  "name": "@qi/core API Documentation",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeExternals": true,
  "includeVersion": true,
  "githubPages": true,
  "plugin": ["typedoc-plugin-markdown"],
  "theme": "markdown",
  "readme": "none",
  "categorize": true,
  "categoryOrder": [
    "Models",
    "Database",
    "Cache",
    "Utils",
    "Config",
    "Errors",
    "*"
  ]
}