{
  "name": "qi",
  "version": "1.0.0",
  "description": "The data platform",
  "type": "module",
  "workspaces": [
    "core",
    "api",
    "producer",
    "consumer"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "pretest": "npm run build",
    "test": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest",
    "test:watch": "npm test -- --watch",
    "test:utils_index": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest core/tests/unit/utils.test.ts",
    "test:errors": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest core/tests/unit/errors.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@types/dotenv": "^8.2.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.8.7",
    "@types/pg": "^8.11.10",
    "@types/testing-library__jest-dom": "^5.14.9",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdoc": "^4.0.4",
    "pg-hstore": "^2.3.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "exports": {
    "./core": {
      "import": "./core/dist/index.js"
    },
    "./core/*": {
      "import": "./core/dist/*/index.js"
    },
    "./api": {
      "import": "./api/dist/index.js"
    },
    "./api/*": {
      "import": "./api/dist/*.js"
    },
    "./producer": {
      "import": "./producer/dist/index.js"
    },
    "./producer/*": {
      "import": "./producer/dist/*.js"
    },
    "./consumer": {
      "import": "./consumer/dist/index.js"
    },
    "./consumer/*": {
      "import": "./consumer/dist/*.js"
    }
  },
  "dependencies": {
    "@types/express": "^5.0.0",
    "ajv": "^8.17.1",
    "axios": "^1.7.7",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "esm": "^3.2.25",
    "fs-extra": "^11.2.0",
    "helmet": "^8.0.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "ramda": "^0.30.1",
    "redis": "^4.7.0",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.5",
    "typedoc": "^0.26.11",
    "typedoc-plugin-markdown": "^4.2.10",
    "winston": "^3.16.0",
    "ws": "^8.18.0",
    "xstate": "^5.18.2"
  }
}
