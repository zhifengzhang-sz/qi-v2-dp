{
  "name": "@qi/core",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -b",
    "lint": "eslint './src/**/*.{ts,js}'",
    "format": "prettier --write './src/**/*.ts'",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "bytes": "^3.1.2",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.2.0",
    "lodash-es": "^4.17.21",
    "retry": "^0.13.1",
    "winston": "^3.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/bytes": "^3.1.4",
    "@types/chai": "^5.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.13",
    "@types/lodash-es": "^4.17.12",
    "@types/mocha": "^10.0.9",
    "@types/node": "^22.9.0",
    "@types/retry": "^0.12.5",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "chai": "^5.1.2",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.12.0",
    "lodash": "^4.17.21",
    "mocha": "^10.8.2",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.js",
      "types": "./dist/*/index.d.ts"
    },
    "./cli/config/*": {
      "import": "./dist/cli/config/*.js",
      "require": "./dist/cli/config/*.js",
      "types": "./dist/cli/config/*.d.ts"
    },
    "./services/config/*": {
      "import": "./dist/services/config/*.js",
      "require": "./dist/services/config/*.js",
      "types": "./dist/services/config/*.d.ts"
    },
    "./services/utils": {
      "import": "./dist/services/utils/index.js",
      "require": "./dist/services/utils/index.js",
      "types": "./dist/services/utils/index.d.ts"
    }
  }
}
