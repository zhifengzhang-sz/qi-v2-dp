# User configuration
USERNAME=your_username
UID=1000
GID=1000
REGISTRY=your_registry
VERSION=latest

# HuggingFace configuration
HF_HOME=./model-cache/huggingface
TRANSFORMERS_CACHE=./model-cache/transformers
HF_TOKEN=your_hf_token_here  # Required for private models

# Model configuration
MODEL_THREADS=8              # Adjust based on your CPU
MODEL_MAX_MEMORY=56G        # Maximum memory allocation
MODEL_MIN_MEMORY=32G        # Minimum memory reservation
MODEL_DEVICE=cpu            # Options: cpu, cuda

# Python development settings
PYTHONPATH=${WORKSPACEFOLDER}
PYTHONUNBUFFERED=1
PYTHONUTF8=1
PYTHONDONTWRITEBYTECODE=1
PYTHONDEVMODE=1
PYTHONWARNINGS=default
TORCH_CPU_THREADS=${MODEL_THREADS}

# Cache management
CACHE_RETENTION_DAYS=30     # Days to keep cached models
CACHE_BACKUP_ENABLED=true   # Enable automatic backups
CACHE_MAX_SIZE=100G        # Maximum cache size