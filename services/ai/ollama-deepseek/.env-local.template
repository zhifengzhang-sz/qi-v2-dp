{
  "MODELS": [
    {
      "name": "{{MODEL_NAME}}",
      "displayName": "{{MODEL_DISPLAY_NAME}}",  // Optional: friendly name for the UI
      "parameters": {
        "num_batch": {{OLLAMA_NUM_BATCH}},
        "num_thread": {{OLLAMA_NUM_THREAD}},
        "num_ctx": {{OLLAMA_NUM_CTX}}
      },
      "endpoints": [
        {
          "type": "ollama",
          "endpointUrl": "http://localhost:11434",  // Local host mapping for your ollama service
          "ollamaName": "{{MODEL_NAME}}:{{MODEL_SIZE}}{{#if MODEL_VARIANT}}-{{MODEL_VARIANT}}{{/if}}"
        }
      ]
    }
  ],
  "otherSettings": {
    "CHAT_UI_PORT": {{UI_PORT}},
    "HF_TOKEN": "{{HF_TOKEN}}"
  }
}
